<%- include('partials/header') %>

<main class="login-container" style="display: flex; align-items: center; justify-content: center; height: 100%;">
    <div class="card" style="width: 100%; max-width: 500px; padding: 2rem; border: 2px solid var(--cor-borda); box-shadow: 6px 6px 0px var(--cor-borda); background-color: var(--cor-fundo); text-align: center;">
        
        <i class="fa-solid fa-triangle-exclamation fa-4x" style="color: var(--cor-destaque); margin-bottom: 20px;"></i>
        
        <h2 style="margin-top: 0;">Oops! Algo deu errado.</h2>
        
        <p style="color: var(--cor-texto-principal); font-size: 1.1rem; margin: 20px 0;">
            <%= mensagem %>
        </p>

        <button onclick="window.history.back()" class="btn btn-primary" style="width: 100%; margin-top: 20px; font-size: 16px;">
            <i class="fa-solid fa-arrow-left"></i> Voltar
        </button>
    </div>
</main>

<%- include('partials/footer') %>